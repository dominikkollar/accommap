# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored — never commit real secrets.

proxmox_endpoint  = "https://pve.lan:8006"
proxmox_api_token = "terraform@pam!accommap=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node      = "pve"

vm_id        = 200
vm_name      = "accommap"
template_id  = 9000        # ID of your Ubuntu 24.04 cloud-image template
cpu_cores    = 2
memory_mb    = 4096
disk_size    = "50G"
datastore    = "local-lvm"
bridge       = "vmbr0"
vlan_tag     = null        # set e.g. 10 if using VLANs

# Static IP example:  "ip=192.168.1.50/24,gw=192.168.1.1"
# DHCP:
ip_config    = "ip=dhcp"
dns_servers  = "1.1.1.1 8.8.8.8"

ci_user        = "ubuntu"
ssh_public_key = "ssh-ed25519 AAAA... you@host"

app_repo_url          = "https://github.com/dominikkollar/accommap.git"
postgres_password     = "change_me_strong_password"
google_places_api_key = ""
